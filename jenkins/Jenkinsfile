pipeline {
    agent any

    environment {
        APP_NAME      = "banking-app"
        APP_VERSION   = "${BUILD_NUMBER}"
        DEPLOY_HOST   = "172.31.8.218"
        DEPLOY_USER   = "ec2-user"
        SSH_KEY       = "/var/lib/jenkins/.ssh/devops-lab-key.pem"
        APP_PORT      = "8090"
        DB_HOST       = "172.31.8.218"
        DB_NAME       = "bankdb"
        DB_USER       = "bankuser"
        DB_PASSWORD   = "bankpassword123"
        API_KEY       = "banking-secret-key-2024"
        // ── JFrog Artifactory (replaces Nexus) ──
        JFROG_URL     = "http://3.106.152.10:8081/artifactory"
        JFROG_REPO    = "banking-docker"
        JFROG_USER    = "admin"
        JFROG_PASS    = "password"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {

        stage('Checkout') {
            steps {
                echo "📥 Checking out source code..."
                git url: 'https://github.com/sathishkrishnan645-design/banking-devops-assessment.git',
                    branch: 'master',
                    credentialsId: 'github-credentials'
                echo "✅ Checkout complete"
            }
        }

        stage('Install Dependencies') {
            steps {
                echo "📦 Installing Python dependencies..."
                dir('app') {
                    sh '''
                        python3 -m venv venv
                        . venv/bin/activate
                        pip install --upgrade pip --quiet
                        pip install -r requirements.txt --quiet
                        pip install pytest pytest-cov pytest-flask --quiet
                        echo "✅ Dependencies installed"
                    '''
                }
            }
        }

        stage('Unit Tests') {
            steps {
                echo "🧪 Running unit tests..."
                dir('app') {
                    sh '''
                        . venv/bin/activate
                        export DATABASE_URL="sqlite:///:memory:"
                        export API_KEY="banking-secret-key-2024"
                        pytest test_app.py -v \
                            --junitxml=test-results.xml \
                            --cov=app \
                            --cov-report=xml:coverage.xml || true
                        echo "✅ Tests complete"
                    '''
                }
            }
            post {
                always {
                    junit 'app/test-results.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo "🔍 Running SonarQube analysis..."
                withSonarQubeEnv('SonarQube') {
                    sh """
                        sonar-scanner \
                            -Dsonar.projectKey=banking-app \
                            -Dsonar.projectName="Banking App" \
                            -Dsonar.sources=app \
                            -Dsonar.exclusions=**/venv/**,**/__pycache__/**,**/test_*.py,**/coverage.xml \
                            -Dsonar.python.coverage.reportPaths=app/coverage.xml \
                            -Dsonar.language=py \
                            -Dsonar.scanner.javaOpts="-Xmx512m"
                    """
                }
                echo "✅ SonarQube analysis complete"
            }
        }

        stage('Docker Build') {
            steps {
                echo "🐳 Building Docker image..."
                dir('app') {
                    sh """
                        docker build -t ${APP_NAME}:${APP_VERSION} -t ${APP_NAME}:latest .
                        echo "✅ Docker image built: ${APP_NAME}:${APP_VERSION}"
                        docker images | grep ${APP_NAME}
                    """
                }
            }
        }

        stage('Push to JFrog') {
            steps {
                echo "📤 Pushing Docker image to JFrog Artifactory..."
                sh """
                    # Save Docker image as tar file
                    echo "💾 Saving image as tar: ${APP_NAME}:${APP_VERSION}..."
                    docker save ${APP_NAME}:${APP_VERSION} -o /tmp/${APP_NAME}-${APP_VERSION}.tar

                    # Upload versioned image to JFrog Generic repo
                    echo "⬆️  Uploading ${APP_NAME}-${APP_VERSION}.tar to JFrog..."
                    curl -u ${JFROG_USER}:${JFROG_PASS} \
                        -X PUT \
                        "${JFROG_URL}/${JFROG_REPO}/${APP_NAME}-${APP_VERSION}.tar" \
                        -T /tmp/${APP_NAME}-${APP_VERSION}.tar \
                        --progress-bar

                    # Also upload as latest
                    echo "⬆️  Uploading ${APP_NAME}-latest.tar to JFrog..."
                    curl -u ${JFROG_USER}:${JFROG_PASS} \
                        -X PUT \
                        "${JFROG_URL}/${JFROG_REPO}/${APP_NAME}-latest.tar" \
                        -T /tmp/${APP_NAME}-${APP_VERSION}.tar \
                        --progress-bar

                    # Verify upload via JFrog Storage API
                    echo "🔍 Verifying upload in JFrog..."
                    curl -s -u ${JFROG_USER}:${JFROG_PASS} \
                        "${JFROG_URL}/api/storage/${JFROG_REPO}/${APP_NAME}-${APP_VERSION}.tar" \
                        | grep -o '"size" : "[^"]*"'

                    # Cleanup local tar
                    rm -f /tmp/${APP_NAME}-${APP_VERSION}.tar

                    echo "✅ Image pushed to JFrog: ${JFROG_URL}/${JFROG_REPO}/${APP_NAME}-${APP_VERSION}.tar"
                """
            }
        }

        stage('Deploy to Server') {
            steps {
                echo "🚀 Deploying to ${DEPLOY_HOST}..."
                sh """
                    set -e

                    echo "📦 Transferring Docker image to deploy server..."
                    docker save ${APP_NAME}:${APP_VERSION} | \
                        ssh -o StrictHostKeyChecking=no \
                            -o ConnectTimeout=30 \
                            -i ${SSH_KEY} \
                            ${DEPLOY_USER}@${DEPLOY_HOST} \
                        "docker load"

                    echo "🔄 Restarting container on deploy target..."
                    ssh -o StrictHostKeyChecking=no \
                        -o ConnectTimeout=30 \
                        -i ${SSH_KEY} \
                        ${DEPLOY_USER}@${DEPLOY_HOST} \
                        "
                        sudo docker stop banking-app 2>/dev/null || true
                        sudo docker rm   banking-app 2>/dev/null || true

                        sudo docker run -d \
                            --name banking-app \
                            --restart unless-stopped \
                            -p ${APP_PORT}:${APP_PORT} \
                            -e DB_HOST=${DB_HOST} \
                            -e DB_PORT=5432 \
                            -e DB_NAME=${DB_NAME} \
                            -e DB_USER=${DB_USER} \
                            -e DB_PASSWORD=${DB_PASSWORD} \
                            -e API_KEY=${API_KEY} \
                            ${APP_NAME}:${APP_VERSION}

                        sudo docker ps | grep banking-app
                        "

                    echo "✅ Deployment complete"
                """
            }
        }

        stage('Health Check') {
            steps {
                echo "❤️  Verifying application health..."
                sh """
                    sleep 15
                    for i in 1 2 3 4 5; do
                        HTTP_CODE=\$(curl -s -o /dev/null -w "%{http_code}" \
                            --connect-timeout 10 \
                            http://${DEPLOY_HOST}:${APP_PORT}/health || echo "000")
                        echo "Attempt \$i: HTTP \$HTTP_CODE"
                        if [ "\$HTTP_CODE" = "200" ]; then
                            echo "✅ Application is healthy!"
                            exit 0
                        fi
                        sleep 5
                    done
                    echo "❌ Health check failed"
                    exit 1
                """
            }
        }

    }

    post {
        success {
            echo "✅ Pipeline SUCCESS - ${APP_NAME}:${APP_VERSION} deployed and archived in JFrog"
        }
        failure {
            echo "❌ Pipeline FAILED - check logs above"
        }
        always {
            sh "docker image prune -f || true"
            cleanWs()
        }
    }
}
