pipeline {
    agent any

    environment {
        APP_NAME     = "banking-app"
        DEPLOY_HOST  = "3.25.174.66"
        APP_PORT     = "8090"
        DB_HOST      = "172.31.8.218"
        SONAR_HOST   = "http://16.176.220.31:9000"
        GIT_REPO     = "https://github.com/sathishkrishnan645-design/banking-devops-assessment.git"
    }

    stages {

        stage('Checkout') {
            steps {
                echo "📥 Checking out source code from GitHub..."
                git branch: 'master',
                    credentialsId: 'github-credentials',
                    url: "${GIT_REPO}"
                echo "✅ Checkout complete"
            }
        }

        stage('Install Dependencies') {
            steps {
                echo "📦 Installing Python dependencies..."
                sh '''
                    cd app
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install --upgrade pip --quiet
                    pip install -r requirements.txt --quiet
                    pip install pytest pytest-cov --quiet
                    echo "✅ Dependencies installed"
                '''
            }
        }

        stage('Unit Tests') {
            steps {
                echo "🧪 Running unit tests..."
                sh '''
                    cd app
                    . venv/bin/activate
                    pip install pytest-flask --quiet
                    pytest test_app.py -v \
                        --junitxml=test-results.xml \
                        --cov=app \
                        --cov-report=xml:coverage.xml \
                        2>&1 || true
                    echo "✅ Tests complete"
                '''
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'app/test-results.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo "🔍 Running SonarQube analysis..."
                withSonarQubeEnv('SonarQube') {
                    sh '''
                        sonar-scanner \
                            -Dsonar.projectKey=banking-app \
                            -Dsonar.projectName="Banking App" \
                            -Dsonar.sources=app \
                            -Dsonar.python.coverage.reportPaths=app/coverage.xml \
                            -Dsonar.python.xunit.reportPath=app/test-results.xml \
                            -Dsonar.language=py
                        echo "✅ SonarQube analysis complete"
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                echo "🐳 Building Docker image..."
                sh '''
                    cd app
                    docker build -t ${APP_NAME}:${BUILD_NUMBER} -t ${APP_NAME}:latest .
                    echo "✅ Docker image built: ${APP_NAME}:${BUILD_NUMBER}"
                    docker images | grep ${APP_NAME}
                '''
            }
        }

        stage('Deploy to Server') {
            steps {
                echo "🚀 Deploying to ${DEPLOY_HOST}..."
                sshagent(['ansible-ssh-key']) {
                    sh '''
                        docker save ${APP_NAME}:latest | \
                        ssh -o StrictHostKeyChecking=no ec2-user@${DEPLOY_HOST} \
                            "docker load"

                        ssh -o StrictHostKeyChecking=no ec2-user@${DEPLOY_HOST} bash << 'DEPLOY'
                            echo "Stopping old container..."
                            sudo docker stop banking-app 2>/dev/null || true
                            sudo docker rm banking-app 2>/dev/null || true
                            echo "Starting new container..."
                            sudo docker run -d \
                                --name banking-app \
                                --restart unless-stopped \
                                -p 8090:8090 \
                                -e DB_HOST=172.31.8.218 \
                                -e DB_PORT=5432 \
                                -e DB_NAME=bankdb \
                                -e DB_USER=bankuser \
                                -e DB_PASSWORD=bankpassword123 \
                                -e API_KEY=banking-secret-key-2024 \
                                banking-app:latest
                            sudo docker ps | grep banking-app
DEPLOY
                        echo "✅ Deployment complete"
                    '''
                }
            }
        }

        stage('Health Check') {
            steps {
                echo "❤️  Verifying application health..."
                sh '''
                    sleep 10
                    HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
                        http://${DEPLOY_HOST}:${APP_PORT}/health)
                    if [ "$HTTP_CODE" = "200" ]; then
                        echo "✅ Application is healthy! HTTP $HTTP_CODE"
                        curl -s http://${DEPLOY_HOST}:${APP_PORT}/health
                    else
                        echo "❌ Health check failed! HTTP $HTTP_CODE"
                        exit 1
                    fi
                '''
            }
        }
    }

    post {
        success {
            echo "✅ PIPELINE SUCCESS - Build #${BUILD_NUMBER} - App: http://${DEPLOY_HOST}:${APP_PORT}"
        }
        failure {
            echo "❌ Pipeline FAILED - check logs above"
        }
        always {
            sh 'docker image prune -f || true'
            cleanWs()
        }
    }
}
