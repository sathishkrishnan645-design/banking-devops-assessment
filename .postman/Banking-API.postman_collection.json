{
  "info": {
    "name": "Banking DevOps Assessment API",
    "description": "Complete Banking REST API collection — ALB endpoint with all CRUD operations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://banking-alb-1942364575.ap-southeast-2.elb.amazonaws.com",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "banking-secret-key-2024",
      "type": "string"
    },
    {
      "key": "account_number",
      "value": "ACC001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        },
        "description": "Check if the banking app is healthy. No authentication required."
      },
      "response": []
    },
    {
      "name": "2. Create Account",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-API-Key", "value": "{{api_key}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"account_number\": \"{{account_number}}\",\n  \"owner_name\": \"John Doe\",\n  \"initial_balance\": 1000.00\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/accounts",
          "host": ["{{base_url}}"],
          "path": ["accounts"]
        },
        "description": "Create a new bank account with an initial balance."
      },
      "response": []
    },
    {
      "name": "3. Get Balance",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{api_key}}" }
        ],
        "url": {
          "raw": "{{base_url}}/accounts/{{account_number}}/balance",
          "host": ["{{base_url}}"],
          "path": ["accounts", "{{account_number}}", "balance"]
        },
        "description": "Get the current balance of an account."
      },
      "response": []
    },
    {
      "name": "4. Deposit Money",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-API-Key", "value": "{{api_key}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 500.00\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/accounts/{{account_number}}/deposit",
          "host": ["{{base_url}}"],
          "path": ["accounts", "{{account_number}}", "deposit"]
        },
        "description": "Deposit money into an account."
      },
      "response": []
    },
    {
      "name": "5. Withdraw Money",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-API-Key", "value": "{{api_key}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 200.00\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{base_url}}/accounts/{{account_number}}/withdraw",
          "host": ["{{base_url}}"],
          "path": ["accounts", "{{account_number}}", "withdraw"]
        },
        "description": "Withdraw money from an account."
      },
      "response": []
    },
    {
      "name": "6. Transaction History",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-API-Key", "value": "{{api_key}}" }
        ],
        "url": {
          "raw": "{{base_url}}/accounts/{{account_number}}/transactions",
          "host": ["{{base_url}}"],
          "path": ["accounts", "{{account_number}}", "transactions"]
        },
        "description": "Get full transaction history for an account."
      },
      "response": []
    },
    {
      "name": "7. Delete Account",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "X-API-Key", "value": "{{api_key}}" }
        ],
        "url": {
          "raw": "{{base_url}}/accounts/{{account_number}}",
          "host": ["{{base_url}}"],
          "path": ["accounts", "{{account_number}}"]
        },
        "description": "Delete an account. Account must have zero balance."
      },
      "response": []
    },
    {
      "name": "8. Unauthorized Request (No API Key)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/accounts/{{account_number}}/balance",
          "host": ["{{base_url}}"],
          "path": ["accounts", "{{account_number}}", "balance"]
        },
        "description": "Demonstrates 401 Unauthorized when API key is missing."
      },
      "response": []
    }
  ]
}
